# --- App ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/mentor_platform?schema=public"

# --- JWT ---
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# --- Cookies ---
COOKIE_SECRET=replace_with_another_long_random_string
